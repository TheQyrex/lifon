{
  "name": "cupsize-api",
  "version": "1.0.0",
  "private": true,
  "description": "LifonMUSIC backend (Cloudflare Worker + D1 + R2)",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:apply:local": "wrangler d1 migrations apply data --local",
    "db:apply:remote": "wrangler d1 migrations apply data --remote",
    "db:export": "wrangler d1 export data --remote --output=./dump.sql",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
