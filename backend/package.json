{
  "name": "cupsize-api",
  "version": "1.0.0",
  "private": true,
  "description": "LifonMUSIC backend",
  "scripts": {
    "start": "node dist/server.js",
    "build": "tsup src/server.ts --format cjs --out-dir dist --no-splitting --external better-sqlite3",
    "dev:cf": "wrangler dev",
    "typecheck": "tsc --noEmit",
    "typecheck:node": "tsc -p tsconfig.node.json --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "better-sqlite3": "^11.8.1",
    "dotenv": "^16.4.7",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250101.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.7",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "wrangler": "^4.92.0"
  }
}
