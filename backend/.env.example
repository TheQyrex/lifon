# Copy this file to .env and fill in the values
# Run: cp .env.example .env && nano .env

# ── Required ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── CORS ───────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://test.lifonmusic.lol

# ── URLs ───────────────────────────────────────────────────────────────────
# Public URL where /media/* files are accessible (via nginx)
MEDIA_PUBLIC_BASE=https://test.lifonmusic.lol/api/media

# Where bundled frontend assets (audio/*, preview/*) live
ASSETS_BASE=https://test.lifonmusic.lol

# ── Paths (defaults work for the standard deploy layout) ──────────────────
# DB_PATH=/var/www/lifonmusic/backend/data/db.sqlite
# DATA_DIR=/var/www/lifonmusic/backend/data
# MEDIA_DIR=/var/www/lifonmusic/backend/data/media

# ── Optional ───────────────────────────────────────────────────────────────
# Username that becomes admin on first registration
# ADMIN_BOOTSTRAP=youradminusername

# Port the Node.js server listens on (nginx proxies to this)
PORT=3001
